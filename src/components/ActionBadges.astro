---
interface Props {
  actions: Array<{ name: string; description: string }>;
}

const { actions } = Astro.props;
---

<div class="action-badges">
  {actions.map((action) => (
    <div class="action-badge" title={action.description}>
      <span class="action-name">{action.name}</span>
    </div>
  ))}
</div>

<style>
  .action-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin: 2.5rem auto 3rem;
    max-width: 900px;
  }

  .action-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.25rem;
    background: rgba(25, 25, 25, 0.8);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: default;
  }

  .action-badge:hover {
    transform: translateY(-2px);
    border-color: var(--accent-light);
    background: rgba(30, 30, 30, 0.9);
    box-shadow: 0 4px 12px rgba(211, 128, 195, 0.2);
  }

  .action-name {
    color: #E0E0E0;
    font-size: 0.9rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .action-badges {
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .action-badge {
      padding: 0.5rem 1rem;
    }

    .action-name {
      font-size: 0.85rem;
    }
  }
</style>
