---
const features = [
  {
    title: "Zero App Switching",
    description: "Select text, press ⌥C, and get results without leaving your app. No tabs, no scrolling, no copy paste.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>`,
    size: "normal"
  },
  {
    title: "Image to Text",
    description: "Copy a screenshot or image and Cai extracts the text automatically — then run any action on it.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m10 13-2 2 2 2"/><path d="m14 17 2-2-2-2"/></svg>`,
    size: "normal"
  },
  {
    title: "Context Aware",
    description: "Cai detects what app you're in and what you copied — text or images — and tailors its actions to fit.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>`,
    size: "normal"
  },
  {
    title: "100% Local & Private",
    description: "All processing stays on your machine. No telemetry, no tracking, no cloud — your data is yours alone.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    size: "normal"
  },
  {
    title: "Clipboard History",
    description: "Search, pin, and reuse your last 100 clipboard items. Never lose what you copied.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M9 14h6"/><path d="M9 18h6"/><path d="M9 10h6"/></svg>`,
    size: "normal"
  },
  {
    title: "Built-in Chat",
    description: "Ask follow-up questions with Tab, or start a new chat with ⌘N to ask anything — no clipboard needed.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    size: "normal"
  }
];
---

<section class="feature-bento">
  <div class="container">
    <h2 class="section-title">Features <span class="highlight">you'll love</span></h2>
    <p class="section-subtitle">
      Simple by design. Built for speed and privacy with full customization.
    </p>

    <div class="bento-grid">
      {features.map((feature, index) => (
        <div class="bento-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="bento-icon" set:html={feature.icon} />
          <h3 class="bento-title">{feature.title}</h3>
          <p class="bento-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-bento {
    padding: 7rem 0;
    background: #111111;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 520px;
    margin: 0 auto 5rem;
    line-height: 1.65;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .bento-card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 32px;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: scale-in 0.5s ease-out both;
  }

  .bento-card:hover {
    transform: translateY(-6px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(167, 139, 250, 0.25);
    box-shadow: 0 16px 40px rgba(167, 139, 250, 0.1);
  }

  .bento-icon {
    width: 36px;
    height: 36px;
    color: #C4B5FD;
    margin-bottom: 1.25rem;
    transition: color 0.3s ease;
  }

  .bento-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .bento-card:hover .bento-icon {
    color: #F78595;
  }

  .bento-title {
    font-size: 1.15rem;
    color: #FFFFFF;
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .bento-description {
    color: #909090;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .feature-bento {
      padding: 5rem 0;
    }

    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .bento-card {
      padding: 1.5rem;
    }

    .bento-icon {
      width: 30px;
      height: 30px;
    }

    .bento-title {
      font-size: 1.05rem;
    }

    .bento-description {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
