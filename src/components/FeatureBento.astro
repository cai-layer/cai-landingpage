---
const features = [
  {
    title: "100% Local",
    description: "All processing stays on your machine. Your data never leaves your computer.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    size: "normal"
  },
  {
    title: "Privacy First",
    description: "No telemetry, no tracking, no cloud. Your clipboard data is yours alone.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    size: "normal"
  },
  {
    title: "Bring Your Own Model",
    description: "Works with LM Studio, Ollama, and any OpenAI-compatible API. Use the model you trust.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    size: "normal"
  },
  {
    title: "One Shortcut",
    description: "Select text, press ⌥C. That's it. No context switching, no distractions.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>`,
    size: "normal"
  },
  {
    title: "Open Source",
    description: "MIT licensed. Inspect the code, contribute, or fork it. Full transparency.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
    size: "normal"
  },
  {
    title: "Smart Detection",
    description: "Automatically recognizes text types — dates, addresses, JSON, code — and suggests the right action.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
    size: "normal"
  }
];
---

<section class="feature-bento">
  <div class="container">
    <h2 class="section-title">Features <span class="highlight">you'll love</span></h2>
    <p class="section-subtitle">
      Built for people who care about speed, privacy, and simplicity.
    </p>

    <div class="bento-grid">
      {features.map((feature, index) => (
        <div class="bento-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="bento-icon" set:html={feature.icon} />
          <h3 class="bento-title">{feature.title}</h3>
          <p class="bento-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-bento {
    padding: 7rem 0;
    background: #111111;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    text-align: center;
    margin-bottom: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .highlight {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    text-align: center;
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 520px;
    margin: 0 auto 5rem;
    line-height: 1.65;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .bento-card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 20px;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: scale-in 0.5s ease-out both;
  }

  .bento-card:hover {
    transform: translateY(-6px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(167, 139, 250, 0.25);
    box-shadow: 0 16px 40px rgba(167, 139, 250, 0.1);
  }

  .bento-icon {
    width: 36px;
    height: 36px;
    color: #C4B5FD;
    margin-bottom: 1.25rem;
    transition: color 0.3s ease;
  }

  .bento-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .bento-card:hover .bento-icon {
    color: #F78595;
  }

  .bento-title {
    font-size: 1.15rem;
    color: #FFFFFF;
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .bento-description {
    color: #909090;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .feature-bento {
      padding: 5rem 0;
    }

    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .bento-card {
      padding: 1.5rem;
    }

    .bento-icon {
      width: 30px;
      height: 30px;
    }

    .bento-title {
      font-size: 1.05rem;
    }

    .bento-description {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
