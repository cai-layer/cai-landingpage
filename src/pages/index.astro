---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import NewsletterCallout from '../components/NewsletterCallout.astro';
import FeatureCards from '../components/FeatureCards.astro';
import WorksEverywhere from '../components/WorksEverywhere.astro';
import LLMProviders from '../components/LLMProviders.astro';
import DemoSection from '../components/DemoSection.astro';
import FeatureBento from '../components/FeatureBento.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const quickActions = [
  { name: "Ask AI", description: "Run any prompt on your selected text", highlight: true },
  { name: "Reply", description: "Context-aware reply for email or chat", highlight: true },
  { name: "Image to Text (OCR)", description: "Extract text from images and screenshots", highlight: true },
  { name: "Create GitHub Issue", description: "Turn errors and text into GitHub issues with AI-generated titles", highlight: true },
  { name: "Create Linear Ticket", description: "File tickets from any app: terminal, browser, Slack", highlight: true },
  { name: "Create Calendar Event", description: "Create calendar event from text" },
  { name: "Summarize", description: "Create a concise summary" },
  { name: "Fix Grammar", description: "Fix grammar, spelling, and punctuation" },
  { name: "Translate", description: "Translate text to another language" },
  { name: "...", description: "And more" },
];

const customFeatures = [
  { name: "Custom Prompts", description: "Save AI prompts and shell commands for one-tap access", highlight: true },
  { name: "URL Actions", description: "Search Google Drive, Jira, Stack Overflow; any URL with %s becomes an action", highlight: true },
  { name: "Custom Scripts", description: "Run scripts and CLI tools via terminal on your selected text", highlight: true },
  { name: "Custom Destinations", description: "Route results to Slack, Notion, or any app via webhooks, deeplinks, and AppleScript", highlight: true },
  { name: "Community Extensions", description: "Browse and install actions shared by others", secondary: true },
  { name: "Keyboard-First", description: "Type to filter, ⌘1–9 to run. No mouse needed.", secondary: true },
];
---

<Layout title="Cai — Local AI Action Layer for macOS | Free & Open Source">
  <Navbar />
  <Hero />

  <!-- Definition paragraph for AI citability and SEO -->
  <section class="definition">
    <div class="definition-container">
      <p class="definition-text">
        <strong>Cai</strong> is a free, open-source AI action layer for macOS. Select any text or image, press <kbd>⌥C</kbd>, and instantly run custom actions: AI prompts, terminal scripts, URL shortcuts, summaries, translations, OCR, GitHub issues via MCP, Linear tickets. Unlike clipboard managers, Cai acts on your selection, not just stores it. Unlike AI chat apps, it works inline without app switching. Ships with a built-in local AI model (Ministral 3B via MLX). No API key, no account, no setup. Also supports Apple Intelligence on macOS 26+, LM Studio, Ollama, and cloud APIs. Local by default. Cloud optional. MIT licensed.
      </p>
    </div>
  </section>

  <FeatureCards />

  <!-- Demo Section 1: Run quick actions -->
  <DemoSection
    id="quick-actions"
    title='<span class="highlight">Smart actions</span>, ready-to-use.'
    subtitle="Cai reads what you selected (meetings, addresses, code, images) and surfaces the right actions automatically."
    actions={quickActions}
    mediaType="video"
    mediaSrc="/videos/cai-builtin-actions.mp4"
    posterSrc="/videos/cai-builtin-actions-poster.webp"
    mediaAlt="Run quick actions demo"
    backgroundColor="#111111"
  />

  <!-- Demo Section 2: Custom commands & actions -->
  <DemoSection
    id="custom-commands"
    title='Make it <span class="highlight">yours</span>.' 
    subtitle="Build your own custom actions, pipe them and route results anywhere."
    actions={customFeatures}
    mediaType="video"
    mediaSrc="/videos/cai-custom-actions.mp4"
    posterSrc="/videos/cai-custom-actions-poster.webp"
    mediaAlt="Custom commands and actions demo"
    backgroundColor="#0F0F0F"
    linkHref="https://github.com/cai-layer/cai-extensions"
    linkText="Browse community extensions →"
  />

  <!-- Action chains -->
  <section class="chain-section" id="chains">
    <div class="chain-container">
      <p class="chain-eyebrow">Action chains</p>
      <h2 class="chain-title">Build your own <span class="highlight">pipelines</span>.</h2>
      <p class="chain-subtitle">
        Pipe a selection through AI, scripts, destinations, and Apple Shortcuts (in any order). Save the chain once, run it anywhere.
      </p>

      <div class="chain-card">
        <p class="chain-card-title"><span class="chain-trigger">⌥C</span>Translate in place</p>
        <div class="chain-flow">
          <span class="chip chip-input">selection</span>
          <span class="chain-arrow">→</span>
          <span class="chip chip-action">Translate to German</span>
          <span class="chain-arrow">→</span>
          <span class="chip chip-destination">Replace Selection</span>
        </div>
      </div>

      <div class="chain-card">
        <p class="chain-card-title"><span class="chain-trigger">⌥C</span>URL to Slack TLDR</p>
        <div class="chain-flow">
          <span class="chip chip-input">selection</span>
          <span class="chain-arrow">→</span>
          <span class="chip chip-action">fetch article</span>
          <span class="chain-arrow">→</span>
          <span class="chip chip-llm">summarize</span>
          <span class="chain-arrow">→</span>
          <span class="chip chip-destination">Send to Slack</span>
        </div>
      </div>

      <p class="chain-caption">If you can describe it in steps, Cai can run it.</p>
    </div>
  </section>

  <FeatureBento />
  <LLMProviders />
  <WorksEverywhere />
  <FAQ />
  <NewsletterCallout />
  <Footer />
</Layout>

<style>
  .definition {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .definition-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .definition-text {
    color: #808080;
    font-size: 0.92rem;
    line-height: 1.75;
    text-align: center;
  }

  .definition-text strong {
    color: #B0B0B0;
    font-weight: 600;
  }

  .definition-text kbd {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
  }

  /* Action chains section */
  .chain-section {
    background: #0F0F0F;
    padding: 7rem 0;
    text-align: center;
  }

  .chain-container {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .chain-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 600;
    color: #808080;
    margin: 0 0 1rem;
  }

  .chain-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #FFFFFF;
    margin: 0 0 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .chain-title :global(.highlight) {
    background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .chain-subtitle {
    color: #909090;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    max-width: 620px;
    margin: 0 auto 3.25rem;
    line-height: 1.65;
  }

  .chain-card {
    max-width: 720px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .chain-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #B0B0B0;
    margin: 0 0 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
  }

  .chain-trigger {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    background: rgba(167, 139, 250, 0.1);
    border: 1px solid rgba(167, 139, 250, 0.28);
    border-radius: 5px;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    color: #C7B6FF;
    letter-spacing: 0;
    text-transform: none;
    flex-shrink: 0;
  }

  .chain-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.55rem 0.4rem;
    margin: 0;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.85rem;
    border-radius: 8px;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.86rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  /* Selection (entry point): outlined ghost */
  .chip-input {
    background: transparent;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    color: #909090;
    font-style: italic;
  }

  /* Action: solid neutral */
  .chip-action {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #E0E0E0;
  }

  /* Inline LLM: italic with subtle indigo glow */
  .chip-llm {
    background: rgba(167, 139, 250, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.25);
    color: #C7B6FF;
    font-style: italic;
  }

  /* Destination: soft green tint — reads as "lands here / endpoint" */
  .chip-destination {
    background: rgba(110, 200, 130, 0.08);
    border: 1px solid rgba(110, 200, 130, 0.25);
    color: #9BD9AD;
  }

  /* Apple Shortcut: subtle warm accent (Shortcuts.app vibe) */
  .chip-shortcut {
    background: rgba(255, 159, 10, 0.08);
    border: 1px solid rgba(255, 159, 10, 0.25);
    color: #FFC074;
  }
  .chip-shortcut::before {
    content: "⚡";
    margin-right: 0.4rem;
  }

  .chain-arrow {
    color: #505050;
    font-size: 1rem;
    user-select: none;
  }

  .chain-caption {
    color: #707070;
    font-size: 0.95rem;
    font-style: italic;
    margin: 1.5rem 0 0;
  }

  @media (max-width: 640px) {
    .chain-section {
      padding: 5rem 0;
    }

    .chain-card {
      margin-bottom: 2rem;
    }

    .chip {
      font-size: 0.78rem;
      padding: 0.35rem 0.7rem;
    }
  }

  @media (max-width: 768px) {
    .definition {
      padding: 0 0 1.5rem;
    }

    .definition-text {
      font-size: 0.88rem;
    }
  }
</style>
